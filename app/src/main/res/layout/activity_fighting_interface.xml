<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Fighting_interface_activity">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/SkillsSelectionId"
        android:layout_width="400dp"
        android:layout_height="300dp"

        android:visibility="invisible"
        app:layout_constraintBottom_toTopOf="@+id/HLayoutActionsId"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        tools:itemCount="20"
        tools:listitem="Z" />

    <LinearLayout
        android:id="@+id/HLayoutActionsId"
        android:layout_width="match_parent"
        android:layout_height="match_parent"

        android:layout_marginTop="325dp"
        android:orientation="horizontal"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/idSkills"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:text="Skills"
            android:visibility="visible" />

        <Button
            android:id="@+id/idTalk"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:text="Talk"
            android:visibility="visible" />

        <Button
            android:id="@+id/idItems"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:text="Items"
            android:visibility="visible" />

        <Button
            android:id="@+id/idFlee"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:text="Flee"
            android:visibility="visible" />
    </LinearLayout>

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="200dp"
        android:layout_height="150dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/imageView2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.574"
        app:srcCompat="@drawable/player" />

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="200dp"
        android:layout_height="150dp"
        app:layout_constraintBottom_toTopOf="@+id/imageView"
        app:layout_constraintStart_toEndOf="@+id/imageView"
        app:srcCompat="@drawable/ennemy" />

    <TextView
        android:id="@+id/HealthPlayer1Id"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Health Player"
        app:layout_constraintTop_toBottomOf="@+id/imageView"
        tools:layout_editor_absoluteX="69dp" />

    <TextView
        android:id="@+id/HealthPlayer2Id"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Health enemy"
        app:layout_constraintTop_toBottomOf="@+id/imageView2"
        tools:layout_editor_absoluteX="253dp" />


</androidx.constraintlayout.widget.ConstraintLayout>